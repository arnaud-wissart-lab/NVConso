<Window x:Class="NVConso.Views.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WattPilot - Préférences"
        Width="920"
        Height="720"
        MinWidth="780"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WattPilot;component/Themes/LightTheme.xaml" />
                <ResourceDictionary Source="/WattPilot;component/Themes/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Background="{DynamicResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,1,0,0"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Enregistrer" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                    <Button Content="OK" Style="{StaticResource PrimaryButton}" Click="Ok_Click" Margin="0,0,8,0" />
                    <Button Content="Annuler" Click="Cancel_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Margin="{StaticResource PagePadding}">
            <TabItem Header="Général">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.ColumnSpan="2" Text="Interface" Style="{StaticResource SectionTitleText}" />
                                <TextBlock Grid.Row="1" Text="Thème" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}" DisplayMemberPath="Label" MaxWidth="260" HorizontalAlignment="Left" />
                                <CheckBox Grid.Row="2" Grid.ColumnSpan="2" Content="Afficher le tableau de bord au démarrage" IsChecked="{Binding ShowDashboardOnStartup}" />
                                <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="GPU au démarrage" Style="{StaticResource SectionTitleText}" Margin="0,16,0,10" />
                                <CheckBox Grid.Row="4" Grid.ColumnSpan="2" Content="Appliquer automatiquement le profil sauvegardé" IsChecked="{Binding AutoApplySavedMode}" />
                                <TextBlock Grid.Row="5" Text="Profil" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox ItemsSource="{Binding StartupProfileOptions}" SelectedItem="{Binding SelectedStartupProfile}" DisplayMemberPath="Label" Width="220" />
                                    <TextBox Text="{Binding CustomPowerLimitWatts, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsCustomPowerLimitEnabled}" Width="90" Margin="10,0,0,0" />
                                    <TextBlock Text="W" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="6,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="GPU" Style="{StaticResource SectionTitleText}" />
                                <TextBlock Text="{Binding GpuRange}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Canicule Guard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.ColumnSpan="2" Text="Surveillance puissance et température" Style="{StaticResource SectionTitleText}" />
                            <CheckBox Grid.Row="1" Grid.ColumnSpan="2" Content="Activer Canicule Guard" IsChecked="{Binding CaniculeGuardEnabled}" />
                            <TextBlock Grid.Row="2" Text="Seuil puissance" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CaniculePowerThresholdWatts, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" />
                            <TextBlock Grid.Row="3" Text="Seuil température" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CaniculeTemperatureThresholdCelsius, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="4" Text="Délai avant alerte" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CaniculeAlertDelaySeconds, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="5" Text="Cooldown" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CaniculeCooldownSeconds, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" />
                            <Button Grid.Row="6" Grid.Column="1" Content="Réinitialiser ces valeurs" Command="{Binding ResetCaniculeGuardCommand}" Width="190" HorizontalAlignment="Left" Margin="0,14,0,0" />
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Affichage">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.ColumnSpan="2" Text="Profils écran" Style="{StaticResource SectionTitleText}" />
                                <CheckBox Grid.Row="1" Grid.ColumnSpan="2" Content="Activer les profils écran" IsChecked="{Binding EnableDisplayProfiles}" />
                                <CheckBox Grid.Row="2" Grid.ColumnSpan="2" Content="Restaurer l'état écran initial sur Stock" IsChecked="{Binding RestoreDisplayStateOnStock}" />
                                <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Content="Restaurer l'état écran initial à la fermeture" IsChecked="{Binding RestoreDisplayStateOnExit}" />
                                <TextBlock Grid.Row="4" Text="Canicule cible (Hz)" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CaniculeTargetRefreshRateHz, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" />
                                <TextBlock Grid.Row="5" Text="Vidéo / surf cible (Hz)" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding VideoSurfTargetRefreshRateHz, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" />
                                <TextBlock Grid.Row="6" Text="Indie 2D cible (Hz)" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Indie2DTargetRefreshRateHz, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" />
                                <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button Content="Paramètres HDR" Command="{Binding OpenHdrSettingsCommand}" Margin="0,0,8,0" />
                                    <Button Content="Graphiques Windows" Command="{Binding OpenGraphicsSettingsCommand}" Margin="0,0,8,0" />
                                    <Button Content="Panneau NVIDIA" Command="{Binding OpenNvidiaSettingsCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="État détecté" Style="{StaticResource SectionTitleText}" />
                                <TextBlock Text="{Binding DisplayStatus}" Margin="0,0,0,8" />
                                <TextBox Text="{Binding DisplayDevices}" MinHeight="150" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                                <CheckBox Content="Autoriser les changements HDR expérimentaux" IsChecked="{Binding AllowExperimentalHdrChanges}" Margin="0,12,0,0" />
                                <CheckBox Content="Autoriser les changements VRR expérimentaux" IsChecked="{Binding AllowExperimentalVrrChanges}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Historisation">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.ColumnSpan="2" Text="Télémétrie persistée" Style="{StaticResource SectionTitleText}" />
                            <CheckBox Grid.Row="1" Grid.ColumnSpan="2" Content="Activer l'historisation GPU" IsChecked="{Binding RecordingEnabled}" />
                            <TextBlock Grid.Row="2" Text="Intervalle d'écriture (s)" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RecordingIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" />
                            <TextBlock Grid.Row="3" Text="Rétention (jours)" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TelemetryRetentionDays, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="4" Text="Historique graphique (s)" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding TelemetryHistorySeconds, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="5" Text="Seuil pic puissance (W)" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding PeakPowerThresholdWatts, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="6" Text="Seuil pic température (°C)" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding PeakTemperatureThresholdCelsius, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" />
                            <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Margin="0,14,0,0">
                                <TextBlock Text="{Binding TelemetryPath}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Ouvrir dossier" Command="{Binding OpenTelemetryFolderCommand}" Margin="0,0,8,0" />
                                    <Button Content="Exporter session" Click="ExportTelemetry_Click" Margin="0,0,8,0" />
                                    <Button Content="Exporter diagnostic" Click="ExportDiagnostics_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Démarrage">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Tâche planifiée Windows" Style="{StaticResource SectionTitleText}" />
                            <CheckBox Content="Démarrer avec Windows" IsChecked="{Binding StartWithWindows}" />
                            <CheckBox Content="Démarrer réduit dans la zone de notification" IsChecked="{Binding StartMinimized}" />
                            <TextBlock Text="{Binding StartupStatus}" Style="{StaticResource MutedText}" Margin="0,10,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Réparer la tâche" Command="{Binding RepairStartupCommand}" Margin="0,0,8,0" />
                                <Button Content="Supprimer la tâche" Command="{Binding DeleteStartupCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Mises à jour">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Velopack" Style="{StaticResource SectionTitleText}" />
                            <CheckBox Content="Vérifier automatiquement les mises à jour" IsChecked="{Binding AutoCheckUpdates}" />
                            <CheckBox Content="Télécharger automatiquement après détection" IsChecked="{Binding AutoDownloadUpdates}" />
                            <CheckBox Content="Inclure les préversions" IsChecked="{Binding IncludePrereleaseUpdates}" />
                            <TextBlock Text="{Binding UpdateStatus.ExecutionModeLabel}" Margin="0,12,0,4" />
                            <TextBlock Text="{Binding UpdateStatus.Message}" Margin="0,12,0,4" />
                            <TextBlock Text="{Binding UpdateStatus.Detail}" Style="{StaticResource MutedText}" />
                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Rechercher maintenant" Command="{Binding CheckForUpdatesCommand}" Width="190" Margin="0,0,8,8" />
                                <Button Content="Ouvrir GitHub Releases" Command="{Binding OpenGitHubReleasesCommand}" Width="190" Margin="0,0,8,8" />
                                <Button Content="Copier diagnostic update" Command="{Binding CopyUpdateDiagnosticCommand}" Width="210" Margin="0,0,8,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Maintenance">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Préférences locales" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="La réinitialisation ne supprime pas automatiquement la tâche planifiée Windows." Style="{StaticResource MutedText}" Margin="0,0,0,12" />
                            <Button Content="Réinitialiser les préférences locales" Command="{Binding ResetDefaultsCommand}" Width="250" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
