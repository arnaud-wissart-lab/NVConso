<Window x:Class="NVConso.Views.WattPilotWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NVConso.Controls"
        Title="WattPilot"
        Width="1180"
        Height="780"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WattPilot;component/Themes/LightTheme.xaml" />
                <ResourceDictionary Source="/WattPilot;component/Themes/CommonStyles.xaml" />
                <ResourceDictionary Source="/WattPilot;component/Themes/WattPilotWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <controls:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsHomePageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="{StaticResource PagePadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="WattPilot" Style="{StaticResource WindowTitleText}" />
                        <TextBlock Text="Consommation, température et profils GPU"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ProductVersion}"
                                   Style="{StaticResource PreferenceInfoLine}" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Content=""
                                Tag="&#xE81C;"
                                Command="{Binding NavigateHistoryCommand}"
                                Style="{StaticResource IconOnlyButton}"
                                ToolTip="Afficher l'historique détaillé"
                                AutomationProperties.Name="Afficher l'historique détaillé"
                                Margin="0,0,6,0" />
                        <Button Content=""
                                Tag="&#xE713;"
                                Command="{Binding NavigateSettingsCommand}"
                                Style="{StaticResource IconOnlyButton}"
                                ToolTip="Ouvrir les paramètres"
                                AutomationProperties.Name="Ouvrir les paramètres" />
                    </WrapPanel>
                </Grid>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding PrimaryMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:ResponsiveWrapPanel MinItemWidth="205"
                                                          MaxColumns="4"
                                                          ItemSpacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}"
                                    MinHeight="112"
                                    ToolTip="{Binding Tooltip}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Value}"
                                               Style="{StaticResource CompactMetricValueText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,3" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Style="{StaticResource MutedText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <controls:ResponsiveSplitPanel Grid.Row="2"
                                               Margin="0,14,0,0"
                                               PrimaryMinWidth="620"
                                               SecondaryMinWidth="280"
                                               SecondaryMaxWidth="340"
                                               SecondaryWidthRatio="0.28"
                                               ItemSpacing="12">
                    <Border Style="{StaticResource Card}" MinHeight="310">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Puissance"
                                           Style="{StaticResource SectionTitleText}"
                                           Margin="0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PowerChart.Summary}"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <controls:TelemetrySparkline Grid.Row="1"
                                                         Chart="{Binding PowerChart}"
                                                         MinHeight="230" />
                        </Grid>
                    </Border>

                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Aujourd'hui" Style="{StaticResource SectionTitleText}" />
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Max puissance" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="1" Text="{Binding DashboardStatus.MaxPowerToday}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Text="Max température" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DashboardStatus.MaxTemperatureToday}" FontWeight="SemiBold" Margin="12,6,0,0" />
                                    <TextBlock Grid.Row="2" Text="Pics" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DashboardStatus.PeakCountToday}" FontWeight="SemiBold" Margin="12,6,0,0" />
                                </Grid>
                                <Button Content="Ouvrir l'historique détaillé"
                                        Tag="&#xE81C;"
                                        Command="{Binding NavigateHistoryCommand}"
                                        Style="{StaticResource IconTextButton}"
                                        ToolTip="Afficher l'historique détaillé"
                                        Margin="0,14,0,0"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </controls:ResponsiveSplitPanel>
            </Grid>
        </ScrollViewer>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsHistoryPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="{StaticResource PagePadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Historique" Style="{StaticResource WindowTitleText}" />
                        <TextBlock Text="Consommation GPU enregistrée localement."
                                   Style="{StaticResource MutedText}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Content=""
                                Tag="&#xE80F;"
                                Command="{Binding NavigateHomeCommand}"
                                Style="{StaticResource IconOnlyButton}"
                                ToolTip="Revenir à l'accueil"
                                AutomationProperties.Name="Revenir à l'accueil"
                                Margin="0,0,6,0" />
                        <Button Content=""
                                Tag="&#xE713;"
                                Command="{Binding NavigateSettingsCommand}"
                                Style="{StaticResource IconOnlyButton}"
                                ToolTip="Ouvrir les paramètres"
                                AutomationProperties.Name="Ouvrir les paramètres" />
                    </WrapPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Mesures" Style="{StaticResource SectionTitleText}" />
                                <TextBlock Text="{Binding HistoryStatus}"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1" Style="{StaticResource CompactToolbar}">
                                <Button Content=""
                                        Tag="&#xEDE1;"
                                        Click="ExportHistory_Click"
                                        Style="{StaticResource IconOnlyButton}"
                                        ToolTip="Exporter CSV"
                                        AutomationProperties.Name="Exporter CSV"
                                        Margin="0,0,4,0" />
                                <Button Content=""
                                        Tag="&#xE8C8;"
                                        Click="CopyHistorySummary_Click"
                                        Style="{StaticResource IconOnlyButton}"
                                        ToolTip="Copier le résumé"
                                        AutomationProperties.Name="Copier le résumé"
                                        Margin="0,0,4,0" />
                                <Button Content=""
                                        Tag="&#xE72C;"
                                        Command="{Binding RefreshHistoryCommand}"
                                        Style="{StaticResource IconOnlyButton}"
                                        ToolTip="Actualiser"
                                        AutomationProperties.Name="Actualiser"
                                        Margin="0,0,4,0" />
                                <Button Content=""
                                        Tag="&#xE8B7;"
                                        Command="{Binding OpenTelemetryFolderCommand}"
                                        Style="{StaticResource IconOnlyButton}"
                                        ToolTip="Ouvrir le dossier"
                                        AutomationProperties.Name="Ouvrir le dossier" />
                            </WrapPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,10" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="132" />
                                <ColumnDefinition Width="178" />
                                <ColumnDefinition Width="178" />
                                <ColumnDefinition Width="178" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Style="{StaticResource HistoryFilterField}">
                                <TextBlock Text="Date" Style="{StaticResource HistoryFilterLabel}" />
                                <DatePicker SelectedDate="{Binding HistoryDate}"
                                            Style="{StaticResource CompactDatePicker}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Style="{StaticResource HistoryFilterField}">
                                <TextBlock Text="GPU" Style="{StaticResource HistoryFilterLabel}" />
                                <ComboBox ItemsSource="{Binding HistoryGpus}"
                                          SelectedItem="{Binding SelectedHistoryGpu}"
                                          DisplayMemberPath="Label"
                                          Style="{StaticResource CompactComboBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Style="{StaticResource HistoryFilterField}">
                                <TextBlock Text="Profil" Style="{StaticResource HistoryFilterLabel}" />
                                <ComboBox ItemsSource="{Binding HistoryProfiles}"
                                          SelectedItem="{Binding SelectedHistoryProfile}"
                                          DisplayMemberPath="Label"
                                          Style="{StaticResource CompactComboBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Style="{StaticResource HistoryFilterField}">
                                <TextBlock Text="Mesure" Style="{StaticResource HistoryFilterLabel}" />
                                <ComboBox ItemsSource="{Binding HistoryMetrics}"
                                          SelectedItem="{Binding SelectedHistoryMetric}"
                                          DisplayMemberPath="Label"
                                          Style="{StaticResource CompactComboBox}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,2,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding HistoryChart.Summary}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,0,0,8" />
                            <controls:TelemetrySparkline Grid.Row="1"
                                                         Chart="{Binding HistoryChart}"
                                                         MinHeight="200"
                                                         MaxHeight="260" />
                        </Grid>

                        <StackPanel Grid.Row="3" Margin="0,10,0,0">
                            <TextBlock Text="{Binding HistorySummary}" />
                            <Grid Margin="0,6,0,0">
                                <DataGrid ItemsSource="{Binding HistoryPeaks}"
                                          AutoGenerateColumns="False"
                                          Style="{StaticResource ModernDataGrid}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Heure" Binding="{Binding Time}" Width="86" />
                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="145" />
                                        <DataGridTextColumn Header="Diagnostic" Binding="{Binding DiagnosticBadge}" Width="145" />
                                        <DataGridTextColumn Header="Valeur" Binding="{Binding Value}" Width="95">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="{x:Type TextBlock}">
                                                    <Setter Property="TextAlignment" Value="Right" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Profil" Binding="{Binding Profile}" Width="118" />
                                        <DataGridTextColumn Header="GPU" Binding="{Binding Gpu}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Border Style="{StaticResource HistoryEmptyState}"
                                        Visibility="{Binding HistoryPeaks.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                                    <TextBlock Text="Aucun pic enregistré pour cette période."
                                               Style="{StaticResource MutedText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               Margin="16" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>

        <ScrollViewer x:Name="SettingsPage"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding DataContext.IsSettingsPageVisible, ElementName=RootWindow, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="{StaticResource PagePadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Paramètres" Style="{StaticResource WindowTitleText}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding SaveStatusMessage}"
                                   Style="{StaticResource PreferenceInfoLine}" />
                        <Border Style="{StaticResource StatusBadge}"
                                 Margin="0,6,0,0"
                                 Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Enregistrement automatique en attente"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Content=""
                                Tag="&#xE72B;"
                                Command="{Binding DataContext.CloseSettingsPanelCommand, ElementName=RootWindow}"
                                Style="{StaticResource IconOnlyButton}"
                                ToolTip="Retourner à la page précédente"
                                AutomationProperties.Name="Retourner à la page précédente" />
                    </WrapPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="25" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ListBox ItemsSource="{Binding PreferenceSections}"
                             SelectedItem="{Binding SelectedPreferenceSection, Mode=TwoWay}"
                             DisplayMemberPath="Label"
                             Style="{StaticResource PreferenceNavigationList}"
                             ItemContainerStyle="{StaticResource PreferenceNavigationItem}" />

                    <Border Grid.Column="1"
                            Background="{DynamicResource BorderBrush}"
                            Width="1"
                            HorizontalAlignment="Center" />

                    <Grid Grid.Column="2">
                        <StackPanel Visibility="{Binding IsHeatMonitoringSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Surveillance chaleur" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="WattPilot peut vous prévenir si la carte chauffe ou consomme trop longtemps."
                                               Style="{StaticResource PreferenceSectionHelp}" />
                                    <TextBlock Text="La surveillance chaleur ne modifie pas les ventilateurs, ne change pas automatiquement de mode GPU et affiche seulement des alertes."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,12" />
                                    <CheckBox Content="Activer la surveillance" IsChecked="{Binding CaniculeGuardEnabled}" />
                                    <Grid Style="{StaticResource PreferenceFieldRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Réglage des alertes" Style="{StaticResource PreferenceInlineLabel}" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding CaniculePresetOptions}"
                                                  SelectedItem="{Binding SelectedCaniculePreset, Mode=TwoWay}"
                                                  DisplayMemberPath="Label"
                                                  Style="{StaticResource CompactComboBox}"
                                                  MinWidth="190" />
                                    </Grid>
                                    <Grid Style="{StaticResource PreferenceFieldRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Seuil puissance" Style="{StaticResource PreferenceFieldTitle}" />
                                            <TextBlock Text="Watts déclenchant une alerte." Style="{StaticResource PreferenceInfoLine}" />
                                        </StackPanel>
                                        <controls:NumericBox Grid.Column="1"
                                                             Value="{Binding CaniculePowerThresholdWatts, Mode=TwoWay}"
                                                             Minimum="10"
                                                             Maximum="1000"
                                                             Unit="W"
                                                             RecommendationText="{Binding CaniculePowerRecommendation}" />
                                    </Grid>
                                    <Grid Style="{StaticResource PreferenceFieldRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Seuil température" Style="{StaticResource PreferenceFieldTitle}" />
                                            <TextBlock Text="Température déclenchant une alerte." Style="{StaticResource PreferenceInfoLine}" />
                                        </StackPanel>
                                        <controls:NumericBox Grid.Column="1"
                                                             Value="{Binding CaniculeTemperatureThresholdCelsius, Mode=TwoWay}"
                                                             Minimum="30"
                                                             Maximum="110"
                                                             Unit="°C"
                                                             RecommendationText="{Binding CaniculeTemperatureRecommendation}" />
                                    </Grid>
                                    <Grid Style="{StaticResource PreferenceFieldRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Délai avant première alerte" Style="{StaticResource PreferenceInlineLabel}" />
                                        <controls:NumericBox Grid.Column="1"
                                                             Value="{Binding CaniculeAlertDelaySeconds, Mode=TwoWay}"
                                                             Minimum="1"
                                                             Maximum="3600"
                                                             Unit="secondes"
                                                             RecommendationText="{Binding CaniculeAlertDelayRecommendation}" />
                                    </Grid>
                                    <Grid Style="{StaticResource PreferenceFieldRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Délai avant nouvelle alerte" Style="{StaticResource PreferenceInlineLabel}" />
                                        <controls:NumericBox Grid.Column="1"
                                                             Value="{Binding CaniculeCooldownSeconds, Mode=TwoWay}"
                                                             Minimum="10"
                                                             Maximum="86400"
                                                             Unit="secondes"
                                                             RecommendationText="{Binding CaniculeCooldownRecommendation}" />
                                    </Grid>
                                    <Button Content="Valeurs recommandées"
                                            Tag="&#xE72C;"
                                            Command="{Binding ResetCaniculeGuardCommand}"
                                            Style="{StaticResource IconTextButton}"
                                            ToolTip="Restaurer les recommandations de surveillance chaleur"
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsHistorySectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Historique" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Les mesures sont enregistrées localement pour comparer vos usages et repérer les pics."
                                               Style="{StaticResource PreferenceSectionHelp}" />
                                    <CheckBox Content="Historiser le GPU" IsChecked="{Binding RecordingEnabled}" />
                                    <Grid Style="{StaticResource PreferenceFieldRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Fréquence d'enregistrement" Style="{StaticResource PreferenceInlineLabel}" />
                                        <controls:NumericBox Grid.Column="1"
                                                             Value="{Binding RecordingIntervalSeconds, Mode=TwoWay}"
                                                             Minimum="1"
                                                             Maximum="60"
                                                             Unit="secondes"
                                                             RecommendationText="{Binding RecordingIntervalRecommendation}" />
                                    </Grid>
                                    <Grid Style="{StaticResource PreferenceFieldRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Conservation des données" Style="{StaticResource PreferenceInlineLabel}" />
                                        <controls:NumericBox Grid.Column="1"
                                                             Value="{Binding TelemetryRetentionDays, Mode=TwoWay}"
                                                             Minimum="1"
                                                             Maximum="365"
                                                             Unit="jours"
                                                             RecommendationText="{Binding TelemetryRetentionRecommendation}" />
                                    </Grid>
                                    <Grid Style="{StaticResource PreferenceFieldRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Durée affichée sur le graphe" Style="{StaticResource PreferenceInlineLabel}" />
                                        <controls:NumericBox Grid.Column="1"
                                                             Value="{Binding TelemetryHistorySeconds, Mode=TwoWay}"
                                                             Minimum="30"
                                                             Maximum="3600"
                                                             Unit="secondes"
                                                             RecommendationText="{Binding TelemetryHistoryRecommendation}" />
                                    </Grid>
                                    <Grid Style="{StaticResource PreferenceFieldRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Seuil pic puissance" Style="{StaticResource PreferenceInlineLabel}" />
                                        <controls:NumericBox Grid.Column="1"
                                                             Value="{Binding PeakPowerThresholdWatts, Mode=TwoWay}"
                                                             Minimum="1"
                                                             Maximum="2000"
                                                             Unit="W"
                                                             RecommendationText="{Binding PeakPowerRecommendation}" />
                                    </Grid>
                                    <Grid Style="{StaticResource PreferenceFieldRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Seuil pic température" Style="{StaticResource PreferenceInlineLabel}" />
                                        <controls:NumericBox Grid.Column="1"
                                                             Value="{Binding PeakTemperatureThresholdCelsius, Mode=TwoWay}"
                                                             Minimum="1"
                                                             Maximum="150"
                                                             Unit="°C"
                                                             RecommendationText="{Binding PeakTemperatureRecommendation}" />
                                    </Grid>
                                    <TextBlock Text="Dossier de données local"
                                               Style="{StaticResource PreferenceFieldLabel}"
                                               ToolTip="{Binding TelemetryPath}" />
                                    <WrapPanel>
                                        <Button Content=""
                                                Tag="&#xE8B7;"
                                                Command="{Binding OpenTelemetryFolderCommand}"
                                                Style="{StaticResource IconOnlyButton}"
                                                ToolTip="Ouvrir le dossier local des données"
                                                AutomationProperties.Name="Ouvrir le dossier local des données"
                                                Margin="0,0,8,8" />
                                        <Button Content=""
                                                Tag="&#xE8C8;"
                                                Command="{Binding CopyTelemetryPathCommand}"
                                                Style="{StaticResource IconOnlyButton}"
                                                ToolTip="Copier le chemin du dossier de données"
                                                AutomationProperties.Name="Copier le chemin du dossier de données"
                                                Margin="0,0,8,8" />
                                        <Button Content=""
                                                Tag="&#xEDE1;"
                                                Click="ExportTelemetry_Click"
                                                Style="{StaticResource IconOnlyButton}"
                                                ToolTip="Exporter la session de télémétrie"
                                                AutomationProperties.Name="Exporter la session de télémétrie"
                                                Margin="0,0,8,8" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsUpdateSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Mise à jour" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Les mises à jour automatiques fonctionnent avec la version installée de WattPilot."
                                               Style="{StaticResource PreferenceSectionHelp}" />
                                    <TextBlock Text="{Binding UpdateStatus.SimpleExecutionModeLabel}" />
                                    <TextBlock Text="{Binding UpdateStatus.SimpleStatusLabel}" Style="{StaticResource PreferenceInfoLine}" />
                                    <TextBlock Text="{Binding UpdateStatus.LastCheckedLabel}" Style="{StaticResource PreferenceInfoLine}" />
                                    <TextBlock Text="Version installée" Style="{StaticResource PreferenceFieldLabel}" />
                                    <TextBlock Text="{Binding UpdateStatus.CurrentVersion}" />
                                    <CheckBox Content="Vérifier automatiquement" IsChecked="{Binding AutoCheckUpdates}" Margin="0,12,0,0" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Content="Vérifier maintenant"
                                                Tag="&#xE721;"
                                                Command="{Binding CheckForUpdatesCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Rechercher les mises à jour disponibles"
                                                Margin="0,0,8,8" />
                                        <Button Content=""
                                                Tag="&#xE8A7;"
                                                Command="{Binding OpenGitHubReleasesCommand}"
                                                Style="{StaticResource IconOnlyButton}"
                                                ToolTip="Ouvrir la page GitHub Releases"
                                                AutomationProperties.Name="Ouvrir la page GitHub Releases"
                                                Margin="0,0,8,8" />
                                        <Button Content="{Binding UpdateStatus.PrimaryActionLabel}"
                                                Tag="&#xE895;"
                                                Command="{Binding PrimaryUpdateCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Télécharger ou installer la mise à jour disponible"
                                                Visibility="{Binding UpdateStatus.CanRunPrimaryAction, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Margin="0,0,8,8" />
                                    </WrapPanel>
                                    <Expander Header="Détails techniques" IsExpanded="False" Margin="0,8,0,0">
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Text="Version installée complète" Style="{StaticResource PreferenceFieldLabel}" />
                                            <TextBlock Text="{Binding UpdateStatus.FullCurrentVersion}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="Version disponible complète" Style="{StaticResource PreferenceFieldLabel}" />
                                            <TextBlock Text="{Binding UpdateStatus.FullLatestVersion}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding UpdateStatus.ChannelLabel}" Style="{StaticResource PreferenceInfoLine}" />
                                            <TextBlock Text="{Binding UpdateStatus.ExecutionModeLabel}" Style="{StaticResource PreferenceInfoLine}" />
                                            <TextBlock Text="Dernier message technique" Style="{StaticResource PreferenceFieldLabel}" />
                                            <TextBlock Text="{Binding UpdateStatus.LastTechnicalMessage}"
                                                       Style="{StaticResource PreferenceInfoLine}"
                                                       TextWrapping="Wrap" />
                                            <Button Content=""
                                                Tag="&#xE8C8;"
                                                Command="{Binding CopyUpdateDiagnosticCommand}"
                                                Style="{StaticResource IconOnlyButton}"
                                                ToolTip="Copier le diagnostic de mise à jour"
                                                AutomationProperties.Name="Copier le diagnostic de mise à jour"
                                                HorizontalAlignment="Left"
                                                Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsAdvancedSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Avancé" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Réglages système et maintenance. À modifier seulement si nécessaire."
                                               Style="{StaticResource PreferenceSectionHelp}" />
                                    <CheckBox Content="Démarrer avec Windows" IsChecked="{Binding StartWithWindows}" />
                                    <CheckBox Content="Démarrer réduit" IsChecked="{Binding StartMinimized}" />
                                    <CheckBox Content="Télécharger automatiquement les mises à jour" IsChecked="{Binding AutoDownloadUpdates}" />
                                    <CheckBox Content="Inclure les préversions" IsChecked="{Binding IncludePrereleaseUpdates}" />
                                    <TextBlock Text="{Binding StartupStatus}" Style="{StaticResource PreferenceInfoLine}" Margin="0,8,0,10" />
                                    <WrapPanel>
                                        <Button Content="Réparer la tâche"
                                                Tag="&#xE90F;"
                                                Command="{Binding RepairStartupCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Réparer la tâche planifiée de démarrage"
                                                Margin="0,0,8,8" />
                                        <Button Content="Supprimer la tâche"
                                                Tag="&#xE74D;"
                                                Command="{Binding DeleteStartupCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Supprimer la tâche planifiée de démarrage" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Maintenance" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="La réinitialisation conserve la tâche planifiée Windows." Style="{StaticResource MutedText}" Margin="0,0,0,10" />
                                    <WrapPanel>
                                        <Button Content="Exporter diagnostic"
                                                Tag="&#xEDE1;"
                                                Click="ExportDiagnostics_Click"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Exporter un diagnostic local"
                                                Margin="0,0,8,8" />
                                        <Button Content="Réinitialiser"
                                                Tag="&#xE72C;"
                                                Click="ResetDefaults_Click"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Réinitialiser les préférences locales"
                                                HorizontalAlignment="Left" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
