<Window x:Class="NVConso.Views.WattPilotWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NVConso.Controls"
        Title="WattPilot"
        Width="1180"
        Height="780"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WattPilot;component/Themes/LightTheme.xaml" />
                <ResourceDictionary Source="/WattPilot;component/Themes/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <Style x:Key="FactLabelText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MutedText}">
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="FactValueText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="CompactMetricValueText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MetricValueText}">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="LineHeight" Value="28" />
            </Style>

            <Style x:Key="PanelSectionBorder" TargetType="{x:Type Border}" BasedOn="{StaticResource Card}">
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <Style x:Key="PreferenceNavigationList" TargetType="{x:Type ListBox}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            </Style>

            <Style x:Key="PreferenceNavigationItem" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Margin" Value="0,0,0,4" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="ItemBorder"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SurfaceMutedBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SurfaceMutedBrush}" />
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PreferenceFieldLabel" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MutedText}">
                <Setter Property="Margin" Value="0,10,0,3" />
            </Style>

            <Style x:Key="PreferenceInfoLine" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HelpText}">
                <Setter Property="Margin" Value="0,6,0,0" />
            </Style>

            <Style x:Key="PreferenceSectionHelp" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HelpText}">
                <Setter Property="Margin" Value="0,4,0,14" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsHomePageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="{StaticResource PagePadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="WattPilot" Style="{StaticResource WindowTitleText}" />
                        <TextBlock Text="Consommation, température et profils GPU"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Content="Historique"
                                Tag="&#xE81C;"
                                Command="{Binding NavigateHistoryCommand}"
                                Style="{StaticResource ButtonGhost}"
                                ToolTip="Afficher l'historique détaillé"
                                Margin="0,0,8,0" />
                        <Button Content="Paramètres"
                                Tag="&#xE713;"
                                Command="{Binding NavigateSettingsCommand}"
                                Style="{StaticResource ButtonGhost}"
                                ToolTip="Ouvrir les paramètres" />
                    </WrapPanel>
                </Grid>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding PrimaryMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:ResponsiveWrapPanel MinItemWidth="205"
                                                          MaxColumns="4"
                                                          ItemSpacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}"
                                    MinHeight="112"
                                    ToolTip="{Binding Tooltip}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Value}"
                                               Style="{StaticResource CompactMetricValueText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,3" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Style="{StaticResource MutedText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <controls:ResponsiveSplitPanel Grid.Row="2"
                                               Margin="0,14,0,0"
                                               PrimaryMinWidth="620"
                                               SecondaryMinWidth="280"
                                               SecondaryMaxWidth="340"
                                               SecondaryWidthRatio="0.28"
                                               ItemSpacing="12">
                    <Border Style="{StaticResource Card}" MinHeight="310">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Puissance"
                                           Style="{StaticResource SectionTitleText}"
                                           Margin="0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PowerChart.Summary}"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <controls:TelemetrySparkline Grid.Row="1"
                                                         Chart="{Binding PowerChart}"
                                                         MinHeight="230" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding PowerLimitDiagnosticMessage}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,10,0,0"
                                       Visibility="{Binding HasPowerLimitDiagnosticMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Border>

                    <StackPanel>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Profil" Style="{StaticResource SectionTitleText}" />
                                <ComboBox ItemsSource="{Binding ProfileActions}"
                                          SelectedItem="{Binding SelectedProfileAction, Mode=TwoWay}"
                                          DisplayMemberPath="Label"
                                          MinWidth="210" />
                                <TextBlock Text="{Binding SelectedProfileDescription}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Aujourd'hui" Style="{StaticResource SectionTitleText}" />
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Max puissance" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="1" Text="{Binding DashboardStatus.MaxPowerToday}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Text="Max température" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DashboardStatus.MaxTemperatureToday}" FontWeight="SemiBold" Margin="12,6,0,0" />
                                    <TextBlock Grid.Row="2" Text="Pics" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DashboardStatus.PeakCountToday}" FontWeight="SemiBold" Margin="12,6,0,0" />
                                </Grid>
                                <Button Content="Ouvrir l'historique détaillé"
                                        Tag="&#xE81C;"
                                        Command="{Binding NavigateHistoryCommand}"
                                        Style="{StaticResource IconTextButton}"
                                        ToolTip="Afficher l'historique détaillé"
                                        Margin="0,14,0,0"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </controls:ResponsiveSplitPanel>

                <Expander Grid.Row="3"
                          Header="Détails techniques"
                          IsExpanded="False"
                          Margin="0,14,0,0">
                    <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding TechnicalMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:ResponsiveWrapPanel MinItemWidth="185"
                                                                      MaxColumns="5"
                                                                      ItemSpacing="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SurfaceMutedBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                MinHeight="90">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{StaticResource MutedText}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Value}"
                                                           Style="{StaticResource FactValueText}"
                                                           Margin="0,6,0,2" />
                                                <TextBlock Text="{Binding Subtitle}"
                                                           Style="{StaticResource MutedText}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <WrapPanel Margin="0,12,0,0">
                                <TextBlock Text="{Binding GpuName}"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,8" />
                                <TextBlock Text="{Binding StatusMessage}"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Expander>
            </Grid>
        </ScrollViewer>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsHistoryPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="{StaticResource PagePadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Historique" Style="{StaticResource WindowTitleText}" />
                        <TextBlock Text="Analyse des journaux GPU persistants"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Content="Accueil"
                                Tag="&#xE80F;"
                                Command="{Binding NavigateHomeCommand}"
                                Style="{StaticResource ButtonGhost}"
                                ToolTip="Revenir à l'accueil"
                                Margin="0,0,8,0" />
                        <Button Content="Paramètres"
                                Tag="&#xE713;"
                                Command="{Binding NavigateSettingsCommand}"
                                Style="{StaticResource ButtonGhost}"
                                ToolTip="Ouvrir les paramètres" />
                    </WrapPanel>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Historique" Style="{StaticResource SectionTitleText}" />
                            <WrapPanel Grid.Column="1">
                                <Button Content="Exporter CSV"
                                        Tag="&#xEDE1;"
                                        Click="ExportHistory_Click"
                                        Style="{StaticResource IconTextButton}"
                                        ToolTip="Exporter l'historique filtré au format CSV"
                                        Margin="0,0,8,0" />
                                <Button Content="Copier résumé"
                                        Tag="&#xE8C8;"
                                        Click="CopyHistorySummary_Click"
                                        Style="{StaticResource IconTextButton}"
                                        ToolTip="Copier le résumé de diagnostic" />
                            </WrapPanel>
                        </Grid>

                        <WrapPanel Grid.Row="1" Margin="0,2,0,12">
                            <StackPanel Width="140" Margin="0,0,10,8">
                                <TextBlock Text="Date" Style="{StaticResource MutedText}" />
                                <DatePicker SelectedDate="{Binding HistoryDate}" />
                            </StackPanel>
                            <StackPanel Width="190" Margin="0,0,10,8">
                                <TextBlock Text="GPU" Style="{StaticResource MutedText}" />
                                <ComboBox ItemsSource="{Binding HistoryGpus}" SelectedItem="{Binding SelectedHistoryGpu}" DisplayMemberPath="Label" />
                            </StackPanel>
                            <StackPanel Width="190" Margin="0,0,10,8">
                                <TextBlock Text="Profil" Style="{StaticResource MutedText}" />
                                <ComboBox ItemsSource="{Binding HistoryProfiles}" SelectedItem="{Binding SelectedHistoryProfile}" DisplayMemberPath="Label" />
                            </StackPanel>
                            <StackPanel Width="190" Margin="0,0,10,8">
                                <TextBlock Text="Métrique" Style="{StaticResource MutedText}" />
                                <ComboBox ItemsSource="{Binding HistoryMetrics}" SelectedItem="{Binding SelectedHistoryMetric}" DisplayMemberPath="Label" />
                            </StackPanel>
                            <Button Content="Actualiser"
                                    Tag="&#xE72C;"
                                    Command="{Binding RefreshHistoryCommand}"
                                    Style="{StaticResource IconTextButton}"
                                    ToolTip="Recharger l'historique"
                                    Margin="0,18,8,8" />
                            <Button Content="Ouvrir dossier"
                                    Tag="&#xE8B7;"
                                    Command="{Binding OpenTelemetryFolderCommand}"
                                    Style="{StaticResource IconTextButton}"
                                    ToolTip="Ouvrir le dossier local des données"
                                    Margin="0,18,0,8" />
                        </WrapPanel>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding HistoryChart.Summary}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,0,0,8" />
                            <controls:TelemetrySparkline Grid.Row="1"
                                                         Chart="{Binding HistoryChart}"
                                                         MinHeight="260" />
                        </Grid>

                        <StackPanel Grid.Row="3" Margin="0,12,0,0">
                            <TextBlock Text="{Binding HistorySummary}" />
                            <TextBlock Text="{Binding HistoryStatus}" Style="{StaticResource MutedText}" Margin="0,4,0,10" />
                            <DataGrid ItemsSource="{Binding HistoryPeaks}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      GridLinesVisibility="Horizontal"
                                      MinHeight="150"
                                      Background="{DynamicResource SurfaceBrush}"
                                      Foreground="{DynamicResource PrimaryTextBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Heure" Binding="{Binding Time}" Width="90" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="150" />
                                    <DataGridTextColumn Header="Diagnostic" Binding="{Binding DiagnosticBadge}" Width="155" />
                                    <DataGridTextColumn Header="Valeur" Binding="{Binding Value}" Width="90" />
                                    <DataGridTextColumn Header="Profil" Binding="{Binding Profile}" Width="120" />
                                    <DataGridTextColumn Header="GPU" Binding="{Binding Gpu}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <ScrollViewer x:Name="SettingsPage"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding DataContext.IsSettingsPageVisible, ElementName=RootWindow, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="{StaticResource PagePadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Paramètres" Style="{StaticResource WindowTitleText}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,4,0,0" />
                        <Border Style="{StaticResource StatusBadge}"
                                Margin="0,6,0,0"
                                Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Modifications non enregistrées"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Content="Enregistrer"
                                Tag="&#xE73E;"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                Margin="0,0,8,0" />
                        <Button Content="Retour"
                                Tag="&#xE72B;"
                                Command="{Binding DataContext.CloseSettingsPanelCommand, ElementName=RootWindow}"
                                Style="{StaticResource ButtonGhost}"
                                ToolTip="Retourner à la page précédente" />
                    </WrapPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="25" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ListBox ItemsSource="{Binding PreferenceSections}"
                             SelectedItem="{Binding SelectedPreferenceSection, Mode=TwoWay}"
                             DisplayMemberPath="Label"
                             Style="{StaticResource PreferenceNavigationList}"
                             ItemContainerStyle="{StaticResource PreferenceNavigationItem}" />

                    <Border Grid.Column="1"
                            Background="{DynamicResource BorderBrush}"
                            Width="1"
                            HorizontalAlignment="Center" />

                    <Grid Grid.Column="2">
                        <StackPanel Visibility="{Binding IsGeneralSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Général" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Personnalisez l'apparence et le comportement général de WattPilot."
                                               Style="{StaticResource PreferenceSectionHelp}" />
                                    <TextBlock Text="Thème" Style="{StaticResource PreferenceFieldLabel}" Margin="0,0,0,3" />
                                    <controls:ThemeOptionControl ItemsSource="{Binding ThemeOptions}"
                                                                 SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />
                                    <CheckBox Content="Afficher au démarrage" IsChecked="{Binding ShowDashboardOnStartup}" Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsProfilesSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Modes GPU" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Choisissez comment WattPilot limite la carte graphique selon votre usage."
                                               Style="{StaticResource PreferenceSectionHelp}" />
                                    <CheckBox Content="Appliquer le profil sauvegardé" IsChecked="{Binding AutoApplySavedMode}" />
                                    <TextBlock Text="Mode au démarrage" Style="{StaticResource PreferenceFieldLabel}" />
                                    <ComboBox ItemsSource="{Binding StartupProfileOptions}" SelectedItem="{Binding SelectedStartupProfile}" DisplayMemberPath="Label" />
                                    <TextBlock Text="Limite personnalisée" Style="{StaticResource PreferenceFieldLabel}" />
                                    <controls:NumericBox Value="{Binding CustomPowerLimitWatts, Mode=TwoWay}"
                                                         Minimum="0"
                                                         Maximum="2000"
                                                         Unit="W"
                                                         RecommendationText="{Binding GpuRange}"
                                                         IsEnabled="{Binding IsCustomPowerLimitEnabled}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsHeatMonitoringSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Surveillance chaleur" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="WattPilot peut vous prévenir si la carte chauffe ou consomme trop longtemps."
                                               Style="{StaticResource PreferenceSectionHelp}" />
                                    <TextBlock Text="La surveillance chaleur ne modifie pas les ventilateurs, ne change pas automatiquement de mode GPU et affiche seulement des alertes."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,12" />
                                    <CheckBox Content="Activer la surveillance" IsChecked="{Binding CaniculeGuardEnabled}" />
                                    <TextBlock Text="Seuil puissance" Style="{StaticResource PreferenceFieldLabel}" />
                                    <TextBlock Text="À partir de combien de watts WattPilot doit vous alerter." Style="{StaticResource PreferenceInfoLine}" />
                                    <controls:NumericBox Value="{Binding CaniculePowerThresholdWatts, Mode=TwoWay}"
                                                         Minimum="10"
                                                         Maximum="1000"
                                                         Unit="W"
                                                         RecommendationText="{Binding CaniculePowerRecommendation}" />
                                    <TextBlock Text="Seuil température" Style="{StaticResource PreferenceFieldLabel}" />
                                    <TextBlock Text="À partir de quelle température WattPilot doit vous alerter." Style="{StaticResource PreferenceInfoLine}" />
                                    <controls:NumericBox Value="{Binding CaniculeTemperatureThresholdCelsius, Mode=TwoWay}"
                                                         Minimum="30"
                                                         Maximum="110"
                                                         Unit="°C"
                                                         RecommendationText="{Binding CaniculeTemperatureRecommendation}" />
                                    <TextBlock Text="Délai avant première alerte" Style="{StaticResource PreferenceFieldLabel}" />
                                    <controls:NumericBox Value="{Binding CaniculeAlertDelaySeconds, Mode=TwoWay}"
                                                         Minimum="1"
                                                         Maximum="3600"
                                                         Unit="secondes"
                                                         RecommendationText="{Binding CaniculeAlertDelayRecommendation}" />
                                    <TextBlock Text="Délai avant nouvelle alerte" Style="{StaticResource PreferenceFieldLabel}" />
                                    <controls:NumericBox Value="{Binding CaniculeCooldownSeconds, Mode=TwoWay}"
                                                         Minimum="10"
                                                         Maximum="86400"
                                                         Unit="secondes"
                                                         RecommendationText="{Binding CaniculeCooldownRecommendation}" />
                                    <Button Content="Valeurs recommandées"
                                            Tag="&#xE72C;"
                                            Command="{Binding ResetCaniculeGuardCommand}"
                                            Style="{StaticResource IconTextButton}"
                                            ToolTip="Restaurer les recommandations de surveillance chaleur"
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsHistorySectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Historique" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Les mesures sont enregistrées localement pour comparer vos usages et repérer les pics."
                                               Style="{StaticResource PreferenceSectionHelp}" />
                                    <CheckBox Content="Historiser le GPU" IsChecked="{Binding RecordingEnabled}" />
                                    <TextBlock Text="Fréquence d'enregistrement" Style="{StaticResource PreferenceFieldLabel}" />
                                    <controls:NumericBox Value="{Binding RecordingIntervalSeconds, Mode=TwoWay}"
                                                         Minimum="1"
                                                         Maximum="60"
                                                         Unit="secondes"
                                                         RecommendationText="{Binding RecordingIntervalRecommendation}" />
                                    <TextBlock Text="Conservation des données" Style="{StaticResource PreferenceFieldLabel}" />
                                    <controls:NumericBox Value="{Binding TelemetryRetentionDays, Mode=TwoWay}"
                                                         Minimum="1"
                                                         Maximum="365"
                                                         Unit="jours"
                                                         RecommendationText="{Binding TelemetryRetentionRecommendation}" />
                                    <TextBlock Text="Durée affichée sur le graphe" Style="{StaticResource PreferenceFieldLabel}" />
                                    <controls:NumericBox Value="{Binding TelemetryHistorySeconds, Mode=TwoWay}"
                                                         Minimum="30"
                                                         Maximum="3600"
                                                         Unit="secondes"
                                                         RecommendationText="{Binding TelemetryHistoryRecommendation}" />
                                    <TextBlock Text="Seuil pic puissance" Style="{StaticResource PreferenceFieldLabel}" />
                                    <controls:NumericBox Value="{Binding PeakPowerThresholdWatts, Mode=TwoWay}"
                                                         Minimum="1"
                                                         Maximum="2000"
                                                         Unit="W"
                                                         RecommendationText="{Binding PeakPowerRecommendation}" />
                                    <TextBlock Text="Seuil pic température" Style="{StaticResource PreferenceFieldLabel}" />
                                    <controls:NumericBox Value="{Binding PeakTemperatureThresholdCelsius, Mode=TwoWay}"
                                                         Minimum="1"
                                                         Maximum="150"
                                                         Unit="°C"
                                                         RecommendationText="{Binding PeakTemperatureRecommendation}" />
                                    <TextBlock Text="Dossier de données local"
                                               Style="{StaticResource PreferenceFieldLabel}"
                                               ToolTip="{Binding TelemetryPath}" />
                                    <WrapPanel>
                                        <Button Content="Ouvrir dossier"
                                                Tag="&#xE8B7;"
                                                Command="{Binding OpenTelemetryFolderCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Ouvrir le dossier local des données"
                                                Margin="0,0,8,8" />
                                        <Button Content="Copier le chemin"
                                                Tag="&#xE8C8;"
                                                Command="{Binding CopyTelemetryPathCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Copier le chemin du dossier de données"
                                                Margin="0,0,8,8" />
                                        <Button Content="Exporter"
                                                Tag="&#xEDE1;"
                                                Click="ExportTelemetry_Click"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Exporter la session de télémétrie"
                                                Margin="0,0,8,8" />
                                    </WrapPanel>
                                    <Expander Header="Chemin complet" IsExpanded="False" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding TelemetryPath}"
                                                   Style="{StaticResource PreferenceInfoLine}"
                                                   TextWrapping="Wrap" />
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsUpdateSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Mise à jour" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Les mises à jour automatiques fonctionnent avec la version installée de WattPilot."
                                               Style="{StaticResource PreferenceSectionHelp}" />
                                    <TextBlock Text="{Binding UpdateStatus.ExecutionModeLabel}" />
                                    <TextBlock Text="{Binding UpdateStatus.LastCheckedLabel}" Style="{StaticResource PreferenceInfoLine}" />
                                    <TextBlock Text="{Binding UpdateStatus.Message}" Style="{StaticResource PreferenceInfoLine}" />
                                    <TextBlock Text="Version installée" Style="{StaticResource PreferenceFieldLabel}" />
                                    <TextBlock Text="{Binding UpdateStatus.CurrentVersion}" />
                                    <TextBlock Text="Version disponible" Style="{StaticResource PreferenceFieldLabel}" />
                                    <TextBlock Text="{Binding UpdateStatus.LatestVersion}" />
                                    <CheckBox Content="Vérifier automatiquement" IsChecked="{Binding AutoCheckUpdates}" Margin="0,12,0,0" />
                                    <CheckBox Content="Télécharger automatiquement" IsChecked="{Binding AutoDownloadUpdates}" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Content="Rechercher maintenant"
                                                Tag="&#xE721;"
                                                Command="{Binding CheckForUpdatesCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Rechercher les mises à jour disponibles"
                                                Margin="0,0,8,8" />
                                        <Button Content="Ouvrir GitHub Releases"
                                                Tag="&#xE8A7;"
                                                Command="{Binding OpenGitHubReleasesCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Ouvrir la page GitHub Releases"
                                                Margin="0,0,8,8" />
                                        <Button Content="Copier diagnostic"
                                                Tag="&#xE8C8;"
                                                Command="{Binding CopyUpdateDiagnosticCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Copier le diagnostic de mise à jour" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsAdvancedSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Avancé" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Réglages système et maintenance. À modifier seulement si nécessaire."
                                               Style="{StaticResource PreferenceSectionHelp}" />
                                    <CheckBox Content="Démarrer avec Windows" IsChecked="{Binding StartWithWindows}" />
                                    <CheckBox Content="Démarrer réduit" IsChecked="{Binding StartMinimized}" />
                                    <CheckBox Content="Inclure les préversions" IsChecked="{Binding IncludePrereleaseUpdates}" />
                                    <TextBlock Text="{Binding StartupStatus}" Style="{StaticResource PreferenceInfoLine}" Margin="0,8,0,10" />
                                    <WrapPanel>
                                        <Button Content="Réparer la tâche"
                                                Tag="&#xE90F;"
                                                Command="{Binding RepairStartupCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Réparer la tâche planifiée de démarrage"
                                                Margin="0,0,8,8" />
                                        <Button Content="Supprimer la tâche"
                                                Tag="&#xE74D;"
                                                Command="{Binding DeleteStartupCommand}"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Supprimer la tâche planifiée de démarrage" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelSectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Maintenance" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="La réinitialisation conserve la tâche planifiée Windows." Style="{StaticResource MutedText}" Margin="0,0,0,10" />
                                    <WrapPanel>
                                        <Button Content="Exporter diagnostic"
                                                Tag="&#xEDE1;"
                                                Click="ExportDiagnostics_Click"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Exporter un diagnostic local"
                                                Margin="0,0,8,8" />
                                        <Button Content="Réinitialiser"
                                                Tag="&#xE72C;"
                                                Click="ResetDefaults_Click"
                                                Style="{StaticResource IconTextButton}"
                                                ToolTip="Réinitialiser les préférences locales"
                                                HorizontalAlignment="Left" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
