<Window x:Class="NVConso.ElevationPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autorisation requise"
        Width="430"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WattPilot;component/Themes/LightTheme.xaml" />
                <ResourceDictionary Source="/WattPilot;component/Themes/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource Card}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="MessageText"
                       Style="{StaticResource SectionTitleText}"
                       Margin="0,0,0,8" />
            <TextBlock x:Name="DetailText"
                       Grid.Row="1"
                       Style="{StaticResource MutedText}"
                       Margin="0,0,0,18" />
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelActionButton"
                        Click="Cancel_Click"
                        Style="{StaticResource ButtonSecondary}"
                        MinWidth="92"
                        Margin="0,0,8,0" />
                <Button x:Name="AuthorizeActionButton"
                        Click="Authorize_Click"
                        Style="{StaticResource ButtonPrimary}"
                        MinWidth="104" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
