<Window x:Class="NVConso.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NVConso"
        Width="320"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WattPilot;component/Themes/LightTheme.xaml" />
                <ResourceDictionary Source="/WattPilot;component/Themes/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <Style x:Key="TraySectionLabel" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MutedText}">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="10,8,10,5" />
            </Style>

            <Style x:Key="TrayMenuButton" TargetType="{x:Type Button}" BasedOn="{StaticResource ButtonGhost}">
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Padding" Value="10,7" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Margin" Value="4,1" />
                <Setter Property="ContentTemplate">
                    <Setter.Value>
                        <DataTemplate DataType="{x:Type local:TrayMenuActionItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="22" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Icon}"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Text}"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="&#xE73E;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="12"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Visibility="{Binding IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TrayPrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource ButtonPrimary}">
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="Margin" Value="10,8,10,4" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="6"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="3"
                              Direction="270"
                              Opacity="0.18" />
        </Border.Effect>
        <StackPanel>
            <Button Content="{Binding OpenDashboardItem}"
                    Command="{Binding OpenDashboardItem.Command}"
                    IsEnabled="{Binding OpenDashboardItem.IsEnabled}"
                    ToolTip="{Binding OpenDashboardItem.ToolTipText}"
                    Style="{StaticResource TrayMenuButton}" />

            <TextBlock Text="Modes GPU" Style="{StaticResource TraySectionLabel}" />
            <ItemsControl ItemsSource="{Binding ProfileItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:TrayMenuActionItem}">
                        <Button Content="{Binding}"
                                Command="{Binding Command}"
                                IsEnabled="{Binding IsEnabled}"
                                ToolTip="{Binding ToolTipText}"
                                Style="{StaticResource TrayMenuButton}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="{Binding CustomPowerLimitItem}"
                    Command="{Binding CustomPowerLimitItem.Command}"
                    IsEnabled="{Binding CustomPowerLimitItem.IsEnabled}"
                    ToolTip="{Binding CustomPowerLimitItem.ToolTipText}"
                    Style="{StaticResource TrayMenuButton}" />

            <Border Height="1"
                    Background="{DynamicResource BorderBrush}"
                    Margin="8,8,8,6" />

            <StackPanel Margin="10,0,10,4">
                <TextBlock Text="Mise à jour"
                           Style="{StaticResource TraySectionLabel}"
                           Margin="0,0,0,5" />
                <TextBlock Text="{Binding InstalledVersionLabel}"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding UpdateStatusItem.Text}"
                           Style="{StaticResource MutedText}"
                           Margin="0,3,0,0" />
            </StackPanel>
            <Button Content="{Binding UpdateActionItem.Text}"
                    Command="{Binding UpdateActionItem.Command}"
                    IsEnabled="{Binding UpdateActionItem.IsEnabled}"
                    ToolTip="{Binding UpdateActionItem.ToolTipText}"
                    Visibility="{Binding UpdateActionItem.IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Style="{StaticResource TrayPrimaryButton}" />

            <Border Height="1"
                    Background="{DynamicResource BorderBrush}"
                    Margin="8,6,8,6" />

            <Button Content="{Binding QuitItem}"
                    Command="{Binding QuitItem.Command}"
                    IsEnabled="{Binding QuitItem.IsEnabled}"
                    ToolTip="{Binding QuitItem.ToolTipText}"
                    Style="{StaticResource TrayMenuButton}" />

            <TextBlock Text="{Binding StatusItem.Text}"
                       Style="{StaticResource MutedText}"
                       TextTrimming="CharacterEllipsis"
                       Margin="10,5,10,3" />
        </StackPanel>
    </Border>
</Window>
