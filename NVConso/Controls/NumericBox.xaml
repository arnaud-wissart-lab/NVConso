<UserControl x:Class="NVConso.Controls.NumericBox"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="30"
             SnapsToDevicePixels="True">
    <StackPanel>
        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="{DynamicResource SurfaceBrush}"
                HorizontalAlignment="Left">
            <Grid Width="158">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ValueTextBox"
                         BorderThickness="0"
                         Background="Transparent"
                         Height="28"
                         MinHeight="28"
                         Padding="8,2"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="ValueTextBox_PreviewTextInput"
                         TextChanged="ValueTextBox_TextChanged"
                         LostFocus="ValueTextBox_LostFocus" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Unit, ElementName=Root}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           Margin="6,0,8,0" />
            </Grid>
        </Border>
        <TextBlock Text="{Binding RecommendationText, ElementName=Root}"
                   Style="{StaticResource PreferenceInfoLine}" />
        <TextBlock Style="{StaticResource PreferenceInfoLine}">
            <TextBlock.Text>
                <MultiBinding StringFormat="Bornes : {0} à {1} {2}">
                    <Binding ElementName="Root" Path="Minimum" />
                    <Binding ElementName="Root" Path="Maximum" />
                    <Binding ElementName="Root" Path="Unit" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>
    </StackPanel>
</UserControl>
