<UserControl x:Class="NVConso.Controls.NumericBox"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="34"
             SnapsToDevicePixels="True">
    <StackPanel>
        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="{DynamicResource SurfaceBrush}"
                HorizontalAlignment="Left">
            <Grid Width="170">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ValueTextBox"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="8,5"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="ValueTextBox_PreviewTextInput"
                         TextChanged="ValueTextBox_TextChanged"
                         LostFocus="ValueTextBox_LostFocus" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Unit, ElementName=Root}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           Margin="8,0,10,0" />
            </Grid>
        </Border>
        <TextBlock Text="{Binding RecommendationText, ElementName=Root}"
                   Style="{StaticResource PreferenceInfoLine}" />
    </StackPanel>
</UserControl>
